  MP: {
    name: "Mercado Pago",
    class: "bg-white text-black",
    icon: MercadoPago,
  },
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  JAVASCRIPT: {
    name: "JavaScript",
    class: "bg-[#f7df1e] text-black",
    icon: JavaScript,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#3178c6] text-white",
    icon: TypeScript,
  },
  REACT: {
    name: "React",
    class: "bg-[#23272f] text-[#58c4dc]",
